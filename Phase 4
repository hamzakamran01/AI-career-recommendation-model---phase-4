    "    print(f'Profile: {profile_name}')\n",
    "    print('=' * 65)\n",
    "\n",
    "    # Step 1: Recommendations\n",
    "    recs, user_vec, pred_cat, cat_proba = get_career_recommendations(\n",
    "        profile_dict, model, le, df, feature_cols, top_n=5\n",
    "    )\n",
    "    conf = cat_proba[le.transform([pred_cat])[0]] * 100\n",
    "    print(f'\\nPredicted Career Domain : {pred_cat} ({conf:.1f}% confidence)')\n",
    "    print(f'\\nTop 5 Career Matches:')\n",
    "    print(recs.to_string())\n",
    "\n",
    "    # Step 2: Skill Gap\n",
    "    top_occ = recs.iloc[0]['Title']\n",
    "    gap_df, gaps_to_fix = skill_gap_analysis(\n",
    "        profile_dict, top_occ, df, feature_cols, top_n_gaps=10\n",
    "    )\n",
    "\n",
    "    print(f'\\nSkill Gap vs {top_occ}:')\n",
    "    if gaps_to_fix.empty:\n",
    "        print('Profile meets all requirements for this occupation.')\n",
    "    else:\n",
    "        high   = len(gaps_to_fix[gaps_to_fix['Priority'] == 'HIGH'])\n",
    "        medium = len(gaps_to_fix[gaps_to_fix['Priority'] == 'MEDIUM'])\n",
