   "source": [
    "def skill_gap_analysis(profile_dict, top_occupation_title, df, feature_cols, top_n_gaps=12):\n",
    "    \"\"\"\n",
    "    Compare a user's feature scores against the top recommended occupation.\n",
    "    Returns a gap dataframe and generates a bar chart + learning roadmap.\n",
    "    \"\"\"\n",
    "\n",
    "    occ_row  = df[df['Title'] == top_occupation_title].iloc[0]\n",
    "    gap_data = []\n",
    "\n",
    "    for feat in feature_cols:\n",
    "        if feat == 'RIASEC_Cluster':\n",
    "            continue\n",
    "        user_score  = profile_dict.get(feat, 0.5)\n",
    "        occ_score   = occ_row[feat]\n",
    "        gap         = user_score - occ_score\n",
    "\n",
    "        if   gap < -0.25: priority = 'HIGH'\n",
    "        elif gap < -0.10: priority = 'MEDIUM'\n",
    "        elif gap < 0.0:   priority = 'LOW'\n",
    "        else:             priority = 'MET'\n",
    "\n",
    "        gap_data.append({\n",
    "            'Feature'    : feat,\n",
    "            'User Score' : round(user_score, 3),\n",
    "            'Required'   : round(occ_score, 3),\n",
    "            'Gap'        : round(gap, 3),\n",
    "            'Priority'   : priority\n",
    "        })\n",
    "\n",
    "    gap_df = pd.DataFrame(gap_data).sort_values('Gap')\n",
    "\n",
    "    # Focus on the top N gaps that need work\n",
    "    gaps_to_fix = gap_df[gap_df['Gap'] < 0].head(top_n_gaps)\n",
    "\n",
    "    return gap_df, gaps_to_fix\n",
    "\n",
    "\n",
    "print('Skill gap analysis function defined.')"
   ]
  },
