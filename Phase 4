      "Career Fit Score function defined.\n",
      "Formula: Score = (0.4 x Category Probability + 0.6 x Cosine Similarity) x 100\n"
     ]
    }
   ],
   "source": [
    "def get_career_recommendations(user_profile_dict, model, le, df, feature_cols, top_n=5):\n",
    "    \"\"\"\n",
    "    Generate Top-N career recommendations for a given user profile.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    user_profile_dict : dict\n",
    "        Feature name to score mapping. Any missing features default to 0.5.\n",
    "    model : trained sklearn classifier\n",
    "    le : fitted LabelEncoder for Category\n",
    "    df : full occupation dataframe\n",
    "    feature_cols : list of feature column names\n",
    "    top_n : int, number of recommendations to return\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    recommendations : pd.DataFrame with Title, Category, Career Fit Score\n",
    "    user_vec : np.array of the user feature vector\n",
    "    \"\"\"\n",
    "\n",
    "    # Build user feature vector — missing features default to 0.5\n",
    "    user_vec = np.array([\n",
    "        user_profile_dict.get(feat, 0.5) for feat in feature_cols\n",
    "    ]).reshape(1, -1)\n",
    "\n",
    "    # Stage 1: Classifier category probabilities\n",
    "    cat_proba   = model.predict_proba(user_vec)[0]        # probability per category\n",
    "    pred_cat_id = np.argmax(cat_proba)\n",
    "    pred_cat    = le.inverse_transform([pred_cat_id])[0]\n",
    "\n",
    "    # Stage 2: Cosine similarity against all 873 occupations\n",
    "    occ_matrix  = df[feature_cols].values\n",
    "    sim_scores  = cosine_similarity(user_vec, occ_matrix)[0]\n",
    "\n",
    "    # Map each occupation's category to its classifier probability\n",
    "    cat_prob_map = dict(zip(le.classes_, cat_proba))\n",
    "    df_temp = df.copy()\n",
    "    df_temp['_cosine']   = sim_scores\n",
    "    df_temp['_cat_prob'] = df_temp['Category'].map(cat_prob_map)\n",
    "\n",
    "    # Career Fit Score = weighted combination\n",
    "    df_temp['Career_Fit_Score'] = (\n",
    "        0.4 * df_temp['_cat_prob'] + 0.6 * df_temp['_cosine']\n",
    "    ) * 100\n",
    "\n",
    "    # Return top N\n",
    "    top = (\n",
    "        df_temp[['Title', 'Category', 'Dominant_RIASEC', 'Career_Fit_Score']]\n",
    "        .sort_values('Career_Fit_Score', ascending=False)\n",
    "        .head(top_n)\n",
    "        .reset_index(drop=True)\n",
    "    )\n",
    "    top.index = top.index + 1\n",
    "    top['Career_Fit_Score'] = top['Career_Fit_Score'].round(1)\n",
    "\n",
    "    return top, user_vec.flatten(), pred_cat, cat_proba\n",
    "\n",
    "\n",
    "print('Career Fit Score function defined.')\n",
    "print('Formula: Score = (0.4 x Category Probability + 0.6 x Cosine Similarity) x 100')"
   ]
  },
