    "# Build the full feature list from column name prefixes\n",
    "riasec_cols = [c for c in df.columns if c.startswith('RIASEC_') and c != 'RIASEC_Cluster']\n",
    "ws_cols     = [c for c in df.columns if c.startswith('WS_')]\n",
    "wv_cols     = [c for c in df.columns if c.startswith('WV_')]\n",
    "eng_cols    = [c for c in ['RIASEC_Spread', 'IC_Index', 'Leadership_Social_Score'] if c in df.columns]\n",
    "\n",
    "feature_cols = riasec_cols + ws_cols + wv_cols + eng_cols\n",
    "if 'RIASEC_Cluster' in df.columns:\n",
    "    feature_cols = feature_cols + ['RIASEC_Cluster']\n",
    "\n",
    "# Encode the target variable\n",
    "le = LabelEncoder()\n",
    "df['Category_Encoded'] = le.fit_transform(df['Category'])\n",
    "\n",
    "X = df[feature_cols].copy()\n",
    "y = df['Category_Encoded'].copy()\n",
    "\n",
    "# Stratified split — class proportions preserved in train and test\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, test_size=0.20, random_state=42, stratify=y\n",
    ")\n",
    "\n",
    "print('Feature breakdown:')\n",
    "print(f'  RIASEC interest dimensions : {len(riasec_cols)}')\n",
    "print(f'  Work Style traits          : {len(ws_cols)}')\n",
    "print(f'  Work Values                : {len(wv_cols)}')\n",
    "print(f'  Engineered features        : {len(eng_cols)}')\n",
    "if 'RIASEC_Cluster' in df.columns:\n",
    "    print(f'  KMeans cluster label       : 1')\n",
    "print(f'  Total features             : {len(feature_cols)}')\n",
    "print(f'\\nTrain size : {X_train.shape[0]} occupations')\n",
    "print(f'Test size  : {X_test.shape[0]} occupations')\n",
    "print(f'Classes    : {len(le.classes_)}')"
